cipio": "LORICA", "departamento": "CÓRDOBA", "clase": "sin_oferta", "poblacion_objetivo": 52931.0, "salas_activas": 0.0, "admisiones": 0.0, "demanda_potencial": 149062.00858520012, "penetracion": 0.0, "demanda_insatisfecha": 149062.00858520012, "dist_polo_km": 204.7, "brecha_tipo": "aislamiento", "lat": 9.240789, "lon": -75.816084}, {"cod_mpio": "25126", "municipio": "CAJICÁ", "departamento": "CUNDINAMARCA", "clase": "sin_oferta", "poblacion_objetivo": 52695.0, "salas_activas": 0.0, "admisiones": 0.0, "demanda_potencial": 148397.39552241823, "penetracion": 0.0, "demanda_insatisfecha": 148397.39552241823, "dist_polo_km": 6.7, "brecha_tipo": "conurbacion", "lat": 4.920009, "lon": -74.02298}, {"cod_mpio": "81001", "municipio": "ARAUCA", "departamento": "ARAUCA", "clase": "sin_oferta", "poblacion_objetivo": 51349.0, "salas_activas": 0.0, "admisiones": 0.0, "demanda_potencial": 144606.84813892504, "penetracion": 0.0, "demanda_insatisfecha": 144606.84813892504, "dist_polo_km": 254.8, "brecha_tipo": "aislamiento", "lat": 7.072726, "lon": -70.747408}, {"cod_mpio": "66170", "municipio": "DOSQUEBRADAS", "departamento": "RISARALDA", "clase": "subatendido", "poblacion_objetivo": 104639.0, "salas_activas": 5.0, "admisiones": 150773.0, "demanda_potencial": 294679.85710352636, "penetracion": 0.5116501734525775, "demanda_insatisfecha": 143906.85710352636, "dist_polo_km": 5.8, "brecha_tipo": null, "lat": 4.833131, "lon": -75.675371}], "trace": {"titulo": "Demanda potencial e insatisfecha por municipio", "descripcion": "Año de referencia 2025, banda objetivo pob_15_45.", "fuentes": [{"nombre": "Población por edad", "origen": "DANE — Proyecciones municipales 2020–2035 (edades simples)", "detalle": "Banda pob_15_45 del año 2025, agregada por código DIVIPOLA."}, {"nombre": "Admisiones y salas activas", "origen": "SIREC — 'Salas de Cine Registradas y Activas' (hoja AdmisionesXmunicipio)", "detalle": "Año 2025."}, {"nombre": "Territorio", "origen": "DIVIPOLA — datos.gov.co (gdxc-w37w)", "detalle": "Universo de 1.122 municipios y geolocalización."}], "supuestos": ["La tasa per cápita observada donde SÍ hay cine (promedio ponderado por población, sin polos extremos) aproxima el consumo alcanzable si el acceso no fuera la restricción.", "La población objetivo (banda de edad) concentra la propensión a asistir.", "La demanda insatisfecha se mide sobre RESIDENTES del municipio.", "Penetración ≥ 1 indica que el municipio ya captura toda su demanda residente (y probablemente parte de la de sus vecinos)."], "pasos": [{"n": 1, "nombre": "Tasa de asistencia per cápita de referencia (robusta)", "formula": "tasa_ref = Σ admisiones / Σ poblacion_pob_15_45, sobre municipios con oferta excluyendo polos de atracción (tasa > percentil 90).", "entradas": {"municipios_con_oferta": 97, "polos_excluidos": 10, "tasa_nacional_simple_contraste": 1.9721}, "resultado": 2.8162, "unidad": "admisiones por habitante objetivo al año", "nota": "Promedio ponderado por población; se excluyen satélites que atraen público de otros municipios para no inflar el benchmark."}, {"n": 2, "nombre": "Demanda potencial municipal", "formula": "demanda_potencial(m) = poblacion_objetivo(m) × tasa_ref", "entradas": {"tasa_ref": 2.8162}, "resultado": null, "unidad": "espectadores/año", "nota": "Se aplica a los 1.122 municipios con proyección de población."}, {"n": 3, "nombre": "Demanda insatisfecha por grupo", "formula": "Se clasifican los municipios en tres grupos, sin mezclar métricas:\n1) BRECHA ESTRUCTURAL — municipios con 0 salas activas: toda su demanda potencial residente está sin atender localmente.\n   insatisfecha(m) = demanda_potencial(m)\n2) SUBATENDIDO — municipios con salas pero penetración < 1:\n   penetracion(m) = admisiones_realizadas(m) / demanda_potencial(m)\n   insatisfecha(m) = max(0, demanda_potencial(m) − admisiones_realizadas(m))\n3) POLO DE ATRACCIÓN / SATURADO — penetración ≥ 1: insatisfecha = 0 (atrae público de otros municipios; no se le imputa déficit).", "entradas": {}, "resultado": null, "unidad": "espectadores/año", "nota": "Cada grupo usa una fórmula distinta; nunca se suman peras con manzanas."}, {"n": 4, "nombre": "Totales nacionales y cobertura coherente", "formula": "cobertura_residente = (potencial − insatisfecha) / potencial. Se calcula así (no con admisiones/potencial) porque las admisiones de municipios saturados incluyen público de otros municipios (visitantes), que no pertenecen a su demanda potencial residente.", "entradas": {"potencial_total": 71091040, "insatisfecha_total": 32789448, "admisiones_totales_incl_desplazamiento": 49783675}, "resultado": "53.88%", "unidad": "cobertura residente", "nota": ""}], "limitaciones": ["La brecha estructural sobreestima la necesidad local si los residentes ya se desplazan a un municipio vecino cercano. Para mitigarlo se calcula la distancia (haversine) al polo con cine más cercano y se marca la brecha como 'conurbación' (aparente, a ≤25 km de un polo) o 'aislamiento' (real), de modo que el fomento priorice municipios genuinamente aislados."]}}