# Copia este archivo a `.env` y completa los valores. `.env` está en .gitignore.

# --- API Socrata (datos.gov.co) ---
# El token de la app no es obligatorio pero evita el throttling de peticiones anónimas.
# Solicítalo en https://www.datos.gov.co (perfil de desarrollador).
SOCRATA_APP_TOKEN=
SOCRATA_DOMAIN=www.datos.gov.co

# Identificadores de dataset (4x4) en datos.gov.co
# DIVIPOLA ya está cableado en el código (gdxc-w37w, verificado).
# SIREC: aún no publicado en datos abiertos (lo aporta el equipo).
# DANE: la proyección nacional se descarga del portal DANE (no hay API SODA única).
SIREC_DATASET_ID=
DANE_POBLACION_DATASET_ID=

# --- API de Claude (Anthropic) para narrativas automáticas en el tablero ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- MLflow ---
MLFLOW_TRACKING_URI=./mlruns
